{
  "name": "@rbxts/calamity-phys",
  "version": "1.0.0",
  "description": "An RBXTS TypeScript library for directing anchored parts to follow pseudo-physical trajectories, with support for collision detection and spatial queries; allowing for client-side interpolation of low-step frequency physics simulations provided by the server.",
  "main": "out/init.luau",
  "scripts": {
    "build": "rbxtsc",
    "build:test": "rbxtsc --rojo test.project.json --type game",
    "watch": "rbxtsc -w",
    "prepublishOnly": "npm run build",
    "rojo:build": "rojo build test.project.json -o testPlace.rbxlx",
    "rojo:serve": "rojo serve test.project.json"
  },
  "keywords": [
    "roblox-ts",
    "roblox",
    "calamity",
    "physics",
    "collision",
    "interpolation",
    "client-side",
    "server-side",
    "library",
    "typescript"
  ],
  "author": "irishfix",
  "license": "MIT",
  "types": "out/index.d.ts",
  "files": [
    "out/index.d.ts",
    "out/init.luau"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@rbxts/compiler-types": "^3.0.0-types.0",
    "@rbxts/types": "^1.0.867",
    "roblox-ts": "^3.0.0",
    "typedoc": "^0.28.15",
    "typedoc-github-theme": "^0.3.1",
    "typedoc-material-theme": "^1.4.1",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@rbxts/beacon": "^2.1.1",
    "@rbxts/services": "^1.5.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IrishFix/rbxts-calamity-phys.git"
  },
  "bugs": {
    "url": "https://github.com/IrishFix/rbxts-calamity-phys/issues"
  },
  "homepage": "https://irishfix.github.io/rbxts-calamity-phys/"
}
